DISCORD_TOKEN=
DISCORD_APP_ID=
# Set to a guild id for instant slash command registration during development.
# Leave empty for global registration (takes ~1 hour to propagate).
DISCORD_DEV_GUILD_ID=

# tame.gg/stats base URL. Override to http://localhost:3000/stats for local dev.
TAME_API_BASE=https://tame.gg/stats

# Shared secret with tame.gg's TAME_BOT_TOKEN. Generate with:
#   openssl rand -base64 48
TAME_BOT_TOKEN=

DATABASE_PATH=./data/bot.db
LOG_LEVEL=info

# HTTP port for the /health endpoint. Set to 0 to disable.
HEALTH_PORT=3000
